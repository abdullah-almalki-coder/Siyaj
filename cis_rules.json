{
  "version": "1.0",
  "standard": "CIS Benchmarks",
  "last_updated": "2024-01-01",
  "modules": {
    "ssh": {
      "description": "إعدادات أمان خدمة SSH",
      "rules": [
        {
          "id": "SSH-001",
          "setting": "PermitRootLogin",
          "expected_value": "no",
          "severity": "critical",
          "description": "منع تسجيل الدخول المباشر كـ Root",
          "remediation": "قم بتعديل الإعداد إلى: PermitRootLogin no",
          "cis_reference": "CIS Linux Benchmark 5.2.8"
        },
        {
          "id": "SSH-002",
          "setting": "PasswordAuthentication",
          "expected_value": "no",
          "severity": "critical",
          "description": "تعطيل المصادقة بكلمة المرور واستخدام SSH Keys",
          "remediation": "قم بتعديل الإعداد إلى: PasswordAuthentication no",
          "cis_reference": "CIS Linux Benchmark 5.2.11"
        },
        {
          "id": "SSH-003",
          "setting": "Protocol",
          "expected_value": "2",
          "severity": "critical",
          "description": "استخدام الإصدار الثاني من بروتوكول SSH فقط",
          "remediation": "قم بتعديل الإعداد إلى: Protocol 2",
          "cis_reference": "CIS Linux Benchmark 5.2.1"
        },
        {
          "id": "SSH-004",
          "setting": "X11Forwarding",
          "expected_value": "no",
          "severity": "medium",
          "description": "تعطيل تمرير واجهة X11 الرسومية",
          "remediation": "قم بتعديل الإعداد إلى: X11Forwarding no",
          "cis_reference": "CIS Linux Benchmark 5.2.6"
        },
        {
          "id": "SSH-005",
          "setting": "MaxAuthTries",
          "expected_value": "4",
          "severity": "medium",
          "description": "تحديد الحد الأقصى لمحاولات تسجيل الدخول",
          "remediation": "قم بتعديل الإعداد إلى: MaxAuthTries 4",
          "cis_reference": "CIS Linux Benchmark 5.2.5"
        },
        {
          "id": "SSH-006",
          "setting": "IgnoreRhosts",
          "expected_value": "yes",
          "severity": "medium",
          "description": "تجاهل ملفات Rhosts لمنع المصادقة غير الآمنة",
          "remediation": "قم بتعديل الإعداد إلى: IgnoreRhosts yes",
          "cis_reference": "CIS Linux Benchmark 5.2.9"
        },
        {
          "id": "SSH-007",
          "setting": "HostbasedAuthentication",
          "expected_value": "no",
          "severity": "medium",
          "description": "تعطيل المصادقة المبنية على المضيف",
          "remediation": "قم بتعديل الإعداد إلى: HostbasedAuthentication no",
          "cis_reference": "CIS Linux Benchmark 5.2.9"
        },
        {
          "id": "SSH-008",
          "setting": "PermitEmptyPasswords",
          "expected_value": "no",
          "severity": "critical",
          "description": "منع استخدام كلمات المرور الفارغة",
          "remediation": "قم بتعديل الإعداد إلى: PermitEmptyPasswords no",
          "cis_reference": "CIS Linux Benchmark 5.2.10"
        }
      ]
    },
    "firewall": {
      "description": "إعدادات الجدار الناري",
      "rules": [
        {
          "id": "FW-001",
          "setting": "ufw_status",
          "expected_value": "active",
          "severity": "critical",
          "description": "التحقق من تفعيل الجدار الناري",
          "remediation": "قم بتفعيل الجدار الناري: sudo ufw enable",
          "cis_reference": "CIS Linux Benchmark 3.5.1"
        },
        {
          "id": "FW-002",
          "setting": "default_incoming",
          "expected_value": "deny",
          "severity": "critical",
          "description": "حظر جميع الاتصالات الواردة افتراضياً",
          "remediation": "قم بتعديل السياسة: sudo ufw default deny incoming",
          "cis_reference": "CIS Linux Benchmark 3.5.1"
        },
        {
          "id": "FW-003",
          "setting": "default_outgoing",
          "expected_value": "allow",
          "severity": "low",
          "description": "السماح بجميع الاتصالات الصادرة افتراضياً",
          "remediation": "قم بتعديل السياسة: sudo ufw default allow outgoing",
          "cis_reference": "CIS Linux Benchmark 3.5.1"
        }
      ]
    },
    "users": {
      "description": "إعدادات حسابات المستخدمين",
      "rules": [
        {
          "id": "USR-001",
          "setting": "root_password",
          "expected_value": "locked",
          "severity": "critical",
          "description": "التحقق من قفل حساب Root",
          "remediation": "قم بقفل حساب Root: sudo passwd -l root",
          "cis_reference": "CIS Linux Benchmark 5.4.1"
        },
        {
          "id": "USR-002",
          "setting": "empty_passwords",
          "expected_value": "none",
          "severity": "critical",
          "description": "التحقق من عدم وجود حسابات بكلمات مرور فارغة",
          "remediation": "قم بتعيين كلمة مرور لجميع الحسابات أو تعطيلها",
          "cis_reference": "CIS Linux Benchmark 6.2.1"
        },
        {
          "id": "USR-003",
          "setting": "sudo_group",
          "expected_value": "restricted",
          "severity": "high",
          "description": "التحقق من تقييد صلاحيات Sudo",
          "remediation": "راجع قائمة المستخدمين في مجموعة sudo: getent group sudo",
          "cis_reference": "CIS Linux Benchmark 5.3.1"
        }
      ]
    }
  }
}
